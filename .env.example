# === Сайт ===
PORT=3000
SITE_NAME=Жемчужина-Тараная
SITE_PHONE=
SITE_EMAIL=
SITE_PUBLIC_URL=http://localhost:3000
# На хостинге укажи постоянный адрес, например:
# SITE_PUBLIC_URL=https://zhemchuzhina.onrender.com

# Яндекс.Метрика — номер счётчика (только цифры). Пусто = аналитика выключена,
# CSP при этом не ослабляется. Цель «booking» срабатывает на странице успешной оплаты.
YANDEX_METRIKA_ID=

# Цена за ночь (руб.) — для расчёта оплаты ЮKassa
BOOKING_PRICE_PER_NIGHT=6000

# Сколько минут «висит» бронь со статусом pending и держит даты забронированными
# до подтверждения оплаты через webhook ЮKassa. По истечении — статус expired,
# даты снова свободны. Дефолт 30.
BOOKING_HOLD_MINUTES=30

# === Админ-панель ===
# Пароль для входа на /admin.html. Если не указан — админка недоступна.
ADMIN_PASSWORD=12345

# Ссылка на канал в MAX — кнопка в шапке появляется, если задана
# Пример: https://max.ru/join/xxxxxxx
MAX_CHANNEL_URL=

# === ЮKassa ===
# Личный кабинет: https://yookassa.ru/my/shop-settings
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Webhook в ЮKassa: https://ваш-сайт.ru/api/yookassa/webhook
# Событие: payment.succeeded

# === Pinggy (доступ с телефона) ===
PINGGY_TOKEN=

# === Уведомления админу после оплаты ===
# vk | max | sms | auto (все настроенные) | off
NOTIFY_VIA=vk

# --- VK (рекомендуется, бесплатно) ---
# 1. Создай сообщество → Сообщения → «Сообщения сообщества» Вкл
# 2. Управление → Работа с API → ключ с правом «Сообщения сообщества»
# 3. Напиши сообществу любое сообщение с личной страницы
# 4. VK_ADMIN_PEER_ID = твой числовой id (не username)
#    Узнать: Настройки VK → Адрес страницы (id123456 → peer_id 123456)
VK_ACCESS_TOKEN=
VK_ADMIN_PEER_ID=
VK_API_VERSION=5.199

# --- MAX (если нужен) ---
MAX_BOT_TOKEN=
MAX_ADMIN_USER_ID=
MAX_API_BASE_URL=https://platform-api2.max.ru

# --- SMS (платно, ~2–5 ₽ за смс) — sms.ru ---
# NOTIFY_VIA=sms
# SMS_PROVIDER=smsru
# SMS_API_KEY=
# SMS_ADMIN_PHONE=79001234567

# === Почта гостю (подтверждение брони после оплаты) ===
# Gmail: 2FA → Пароли приложений → пароль для «Почта»
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Жемчужина-Тараная <no-reply@example.com>

# Фискальный чек 54-ФЗ через ЮKassa (вкл. режим проверки чеков в тестовом магазине)
# YOOKASSA_SEND_RECEIPT=false
